# ─────────────────────────────────────────────────────────────
# SOLO OS — Environment Configuration (TEMPLATE)
# Copy this file to `.env` and fill in your values.
# The app RUNS WITHOUT Supabase configured (local-only demo mode),
# but full progression sync requires a Supabase project.
#
# ⚠️  DO NOT put real secrets in this file — it is a shareable template.
#     Put real values in `.env` (which is git-ignored).
# ─────────────────────────────────────────────────────────────

# ── Shared backend (the Next.js website REST API) ──
# This is the canonical backend. Point it at your running website.
#   • Local dev on a simulator:   http://localhost:3000
#   • Physical device on Wi-Fi:   http://<your-computer-LAN-IP>:3000
# When unset, the app runs local-only (no login, no cross-device sync).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ── Supabase (LEGACY / optional) ──
# No longer used by the app now that the website API is the shared backend.
# Left here only for reference; safe to omit.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# AI Provider (OPTIONAL — app works fully without any key via MockAIProvider)
# Supported: mock | claude | openai | gemini
EXPO_PUBLIC_AI_PROVIDER=mock

# NOTE: Real AI API keys must NEVER be shipped in the client.
# They live only in Supabase Edge Function secrets (server-side).
# These client vars only select which provider ECHO talks to via the edge function.

# ─────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY (not used by the app) — for running migrations:
# The direct Postgres connection string is under
# Project Settings -> Database -> Connection string (URI).
# Keep it out of source control; export it in your shell instead, e.g.:
#   export SUPABASE_DB_URL="postgresql://postgres.<ref>:<password>@<host>:5432/postgres"
# ─────────────────────────────────────────────────────────────
