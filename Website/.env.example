# ─────────────────────────────────────────────────────────────
# ASCEND//SYSTEM environment
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL (Supabase) ──
# Prisma needs TWO urls on Supabase because it pools with PgBouncer:
#
#   DATABASE_URL  → Supabase "Transaction pooler" (port 6543). Used at runtime.
#                   Append ?pgbouncer=true&connection_limit=1
#   DIRECT_URL    → Supabase "Session"/direct connection (port 5432).
#                   Used by `prisma db push` / `prisma migrate`.
#
# Find both under: Supabase Dashboard → Project → Connect → ORMs → Prisma.
#
# Supabase example:
#   DATABASE_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#   DIRECT_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres"
#
# Local Postgres (point both at the same server):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ascend?schema=public"
#   DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ascend?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ascend?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ascend?schema=public"

# Auth.js (NextAuth) — generate with: npx auth secret   (or: openssl rand -base64 32)
# NOTE: this same secret also signs the bearer tokens issued to the mobile app
# via /api/auth/login and /api/auth/register.
AUTH_SECRET="replace-me-with-a-long-random-string"

# Base URL of the app (used by Auth.js). Leave as localhost for dev.
AUTH_URL="http://localhost:3000"

# The single player account created by the seed script.
PLAYER_EMAIL="harsh004bathija@gmail.com"
PLAYER_PASSWORD="change-me-after-first-login"
PLAYER_NAME="Harsh Bathija"

# Shared secret for the Vercel Cron daily-quest roll-over (/api/cron/daily-quests).
# Vercel injects this as `Authorization: Bearer <CRON_SECRET>` on scheduled runs.
CRON_SECRET="replace-me-with-a-long-random-string"

# ── AI Guide provider (optional; the app runs without it) ──
# provider: "none" | "anthropic" | "openai" | "gemini"
AI_PROVIDER="none"
AI_API_KEY=""
AI_MODEL="claude-opus-4-8"
